#!/usr/bin/env python3

"""
* Split task file on lines that start with three or more dashes
* Remove empty ones
* Pop the first
* Print it without ---
* Save the popped thing in a different file.

"""

import sys
from collections.abc import Iterable, Iterator
from pathlib import Path


def project_root(path: Path) -> Path:
    for parent in (path, *path.parents):
        if (parent / ".git").exists():
            return parent
    return path


def strip_empty_lines(lines: list[str]) -> list[str]:
    while lines and not lines[0].strip():
        lines.pop(0)
    while lines and not lines[-1].strip():
        lines.pop()
    return lines


def task_lines(task: list[str]) -> tuple[list[str], str]:
    old_line = task.pop() if task and task[-1].startswith("---") else "---\n"
    return strip_empty_lines(task), old_line


def main() -> None:
    name = project_root(Path.cwd()).name
    root = Path(__file__).resolve().parent
    task_file = root / f"{name}.md"
    done_file = root / "done" / f"{name}.md"

    def is_sep(s: str) -> bool:
        return s.startswith("---")

    cuts: list[list[str]] = [[]]
    for line in task_file.open():
        cuts[-1].append(line)
        if is_sep(line):
            cuts.append([])

    while cuts:
        task = cuts.pop(0)
        if any(t.strip() and not is_sep(t) for t in task):
            break
    else:
        sys.exit("No tasks found")

    def remaining_lines(tasks: Iterable[list[str]]) -> Iterator[str]:
        for remaining_task in tasks:
            lines, separator = task_lines(remaining_task)
            if lines:
                yield from lines
                yield separator

    lines, old_line = task_lines(task)
    sys.stdout.writelines(lines)
    with task_file.open("w") as fp:
        fp.writelines(remaining_lines(cuts))
    done_file.parent.mkdir(exist_ok=True)
    with done_file.open("a") as fp:
        fp.writelines(lines)
        fp.write(old_line)


if __name__ == "__main__":
    main()
