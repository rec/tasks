#!/usr/bin/env python3

"""
* Split task file on lines that start with three or more dashes
* Remove empty ones
* Pop the first
* Print it without ---
* Save the popped thing in a different file.

"""

import sys
from collections.abc import Iterable, Iterator
from pathlib import Path


def project_root(path: Path) -> Path:
    for parent in (path, *path.parents):
        if (parent / ".git").exists():
            return parent
    return path


def project_name(args: list[str]) -> str:
    if len(args) > 1:
        sys.exit("Usage: pop [project]")
    if args:
        return args[0]
    return project_root(Path.cwd()).name


def main(project: str | None = None) -> None:
    name = project if project is not None else project_name(sys.argv[1:])
    root = Path(__file__).resolve().parent
    task_file = root / "tasks" / f"{name}.md"
    done_file = root / "done" / f"{name}.md"

    def is_sep(s: str) -> bool:
        return s.startswith("---")

    cuts: list[list[str]] = [[]]
    with task_file.open() as fp:
        for line in fp:
            cuts[-1].append(line)
            if is_sep(line):
                cuts.append([])

    while cuts:
        task = cuts.pop(0)
        if any(t.strip() and not is_sep(t) for t in task):
            break
    else:
        sys.exit("No tasks found")

    def drop_empty(it: Iterable[str]) -> Iterator[str]:
        found = False
        for i in it:
            if found := found or not i.strip():
                yield i

    old_line = task.pop() if is_sep(task[-1]) else "---\n"
    print(*task)
    with task_file.open("w") as fp:
        fp.writelines(drop_empty(i for c in cuts for i in c))
    done_file.parent.mkdir(exist_ok=True)
    with done_file.open("a") as fp:
        fp.write(f"{old_line}\n")
        fp.writelines(drop_empty(task))


if __name__ == "__main__":
    main()
